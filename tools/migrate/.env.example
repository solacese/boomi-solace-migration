# Boomi AtomSphere API
BOOMI_ACCOUNT_ID=your-account-id
BOOMI_USERNAME=your-email@example.com
BOOMI_API_TOKEN=your-api-token

# Solace SEMP v2 (queue provisioning)
SOLACE_SEMP_BASE_URL=https://your-broker:943
SOLACE_MESSAGE_VPN=your-vpn
SOLACE_SEMP_USERNAME=admin
SOLACE_SEMP_PASSWORD=your-semp-password

# Solace Client Connection (embedded in Boomi components)
SOLACE_HOST=tcps://mr-xxxxx.messaging.solace.cloud:55443
SOLACE_CLIENT_USERNAME=solace-cloud-client
SOLACE_CLIENT_PASSWORD=your-client-password
