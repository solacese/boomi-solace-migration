<?xml version='1.0' encoding='UTF-8'?>
<bns:Component xmlns:bns="http://api.platform.boomi.com/"
               componentId="producer-process"
               version="4"
               name="Sample Producer Process"
               type="process"
               folderId="source-folder"
               currentVersion="true"
               folderName="Source">
  <bns:object>
    <process>
      <shape shapetype="connectoraction" userlabel="Send to Sample Queue">
        <connectoraction actionType="Send"
                         connectorType="atomqueue"
                         connectionId="old-conn"
                         operationId="old-op">
          <parameters/>
          <dynamicProperties/>
        </connectoraction>
      </shape>
      <shape shapetype="documentproperties" userlabel="Set Entity DDP">
        <setproperties>
          <propertyvalue childKey="DDP_ENTITY_ID" valueType="static">
            <trackparameter propertyId="dynamicdocument.DDP_ENTITY_ID"
                            propertyName="Dynamic Document Property - DDP_ENTITY_ID"/>
          </propertyvalue>
        </setproperties>
      </shape>
    </process>
  </bns:object>
</bns:Component>
